Note: The DBML file focuses on table structure, while the PNG shows conceptual lineage relationships.

Table bmw_sales_raw {
  year numeric(4) [not null, note: "CHECK year > 2000 AND year < 3000"]
  month numeric(2) [not null, note: "CHECK month > 0 AND month < 13"]
  region varchar(20) [not null]
  model varchar(20) [not null]
  units_sold int [not null, note: "CHECK units_sold >= 0"]
  avg_price_eur int [not null, note: "CHECK avg_price_eur >= 0"]
  revenue_eur int [not null, note: "CHECK revenue_eur >= 0"]
  bev_share numeric(4,3) [not null, note: "CHECK bev_share >= 0 AND bev_share <= 1"]
  premium_share numeric(6,3) [not null, note: "CHECK premium_share >= 0 AND premium_share <= 100"]
  gdp_growth numeric(5,3) [not null]
  fuel_price_index numeric(5,3) [not null, note: "CHECK fuel_price_index >= 0"]

  indexes {
    (year, month, region, model) [pk]
  }

  Note: "Layer: Raw"
}

Table monthly_region_sales {
  year numeric(4) [not null]
  month numeric(2) [not null]
  region varchar(20) [not null]
  total_units_sold int [not null]
  total_avg_price_eur numeric(12,2) [not null]
  total_revenue_eur bigint [not null]

  indexes {
    (year, month, region) [pk]
  }

  Note: "Layer: Aggregation | Derived from: bmw_sales_raw"
}

Table monthly_model_sales {
  year numeric(4) [not null]
  month numeric(2) [not null]
  model varchar(20) [not null]
  total_units_sold int [not null]
  total_avg_price_eur numeric(12,2) [not null]
  total_revenue_eur bigint [not null]

  indexes {
    (year, month, model) [pk]
  }

  Note: "Layer: Aggregation | Derived from: bmw_sales_raw"
}

Table sales_gdp_feature {
  region varchar(20) [not null]
  gdp_growth numeric(5,3) [not null]
  total_premium_share numeric(6,2) [not null]
  total_bev_share numeric(6,3) [not null]
  total_units_sold int [not null]
  total_revenue_eur bigint [not null]

  indexes {
    (region, gdp_growth) [pk]
  }

  Note: "Layer: Feature | Derived from: bmw_sales_raw"
}

Table sales_fuel_index_feature {
  region varchar(20) [not null]
  fuel_price_index_low numeric(4,1) [not null]
  total_premium_share numeric(6,2) [not null]
  total_bev_share numeric(6,3) [not null]
  total_units_sold int [not null]
  total_revenue_eur bigint [not null]

  indexes {
    (region, fuel_price_index_low) [pk]
  }

  Note: "Layer: Feature | Derived from: bmw_sales_raw"
}
