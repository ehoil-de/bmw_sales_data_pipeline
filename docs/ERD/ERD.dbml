Note: The DBML file focuses on table structure, while the PNG shows conceptual lineage relationships.

Table bmw_sales_raw {
  year smallint
  month smallint
  region text
  model text
  units_sold bigint
  avg_price_eur bigint
  revenue_eur bigint
  bev_share double
  premium_share double
  gdp_growth double
  fuel_price_index double

  indexes {
    (year, month, region, model) [pk]
  }

  Note: "Layer: Raw"
}

Table bmw_sales_clean {
  year smallint
  month smallint
  region text
  model text
  units_sold bigint
  avg_price_eur bigint
  revenue_eur bigint
  bev_share double
  premium_share double
  gdp_growth double
  fuel_price_index double

  indexes {
    (year, month, region, model) [pk]
  }

  Note: "Layer: Clean | Derived from: bmw_sales_raw"
}

Table monthly_region_sales {
  year smallint [not null]
  month smallint [not null]
  region text [not null]
  total_units_sold bigint [not null]
  total_avg_price_eur numeric(12,2) [not null]
  total_revenue_eur bigint [not null]

  indexes {
    (year, month, region) [pk]
  }

  Note: "Layer: Aggregation | Derived from: bmw_sales_clean"
}

Table monthly_model_sales {
  year smallint [not null]
